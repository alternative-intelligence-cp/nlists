pub func:failsafe = int32(tbb32:err) { exit 1i32; };
pub func:main = int32(int32:argc, wild int8->:argv) {
    wild int8->:p1 = nodrop alloc(32i64);
    wild int8->:p2 = nodrop alloc(24i64);
    
    int64:addr1 = @cast_unchecked<int64>(p1);
    int64:addr2 = @cast_unchecked<int64>(p2);
    
    if (addr1 == addr2) { dalloc(p1); dalloc(p2); exit 10i32; }
    
    (@cast_unchecked<int64->>(addr1 + 24i64))[0i64] = 42i64;
    (@cast_unchecked<int64->>(addr2 + 0i64))[0i64] = 99i64;
    
    int64:val = (@cast_unchecked<int64->>(addr1 + 24i64))[0i64];
    
    dalloc(p1);
    dalloc(p2);
    
    if (val != 42i64) { exit 20i32; }
    
    exit 0i32;
};
