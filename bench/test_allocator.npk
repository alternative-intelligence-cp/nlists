use "../src/allocator.npk".*;
pub func:failsafe = int32(tbb32:err) { exit 1i32; };
pub func:main = int32(int32:argc, wild int8->:argv) {
    int64:allocator = raw NodeAllocator.create(24i64);
    if (allocator == 0i64) { exit 1i32; }
    int64:node = raw NodeAllocator.alloc(allocator);
    if (node == 0i64) { exit 2i32; }
    drop raw NodeAllocator.free(allocator, node);
    drop raw NodeAllocator.destroy(allocator);
    exit 0i32;
};
