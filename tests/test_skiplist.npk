use "../src/skiplist.npk".*;



func:main = int32() {
    int64:list = raw SkipList_create();
    if (list == 0i64) { exit 1i32; }

    drop SkipList_insert(list, 50i64);
    drop SkipList_insert(list, 10i64);
    drop SkipList_insert(list, 30i64);
    drop SkipList_insert(list, 20i64);
    drop SkipList_insert(list, 40i64);

    if (raw SkipList_count(list) != 5i64) { exit 2i32; }

    if (raw SkipList_contains(list, 30i64) != 1i8) { exit 3i32; }
    if (raw SkipList_contains(list, 100i64) != 0i8) { exit 4i32; }

    drop SkipList_remove(list, 30i64);
    
    if (raw SkipList_contains(list, 30i64) != 0i8) { exit 5i32; }
    if (raw SkipList_count(list) != 4i64) { exit 6i32; }

    drop SkipList_destroy(list);
    
    exit 0i32;
};
