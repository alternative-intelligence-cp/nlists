use "../src/sorted.npk".*;



func:main = int32() {
    int64:list = raw SortedList_create();
    if (list == 0i64) { exit 1i32; }

    drop SortedList_insert(list, 50i64);
    drop SortedList_insert(list, 10i64);
    drop SortedList_insert(list, 30i64);
    drop SortedList_insert(list, 20i64);
    drop SortedList_insert(list, 40i64);

    if (raw SortedList_count(list) != 5i64) { exit 2i32; }

    if (raw SortedList_contains(list, 10i64) != 1i8) { exit 3i32; }
    if (raw SortedList_remove(list, 10i64) != 1i8) { exit 4i32; }
    if (raw SortedList_contains(list, 20i64) != 1i8) { exit 5i32; }
    if (raw SortedList_remove(list, 20i64) != 1i8) { exit 6i32; }
    if (raw SortedList_remove(list, 30i64) != 1i8) { exit 7i32; }
    if (raw SortedList_remove(list, 40i64) != 1i8) { exit 8i32; }
    if (raw SortedList_remove(list, 50i64) != 1i8) { exit 9i32; }
    
    if (raw SortedList_count(list) != 0i64) { exit 10i32; }

    drop SortedList_destroy(list);
    
    exit 0i32;
};
