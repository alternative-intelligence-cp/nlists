use "../src/sorted.npk".*;

pub func:failsafe = int32(tbb32:err) {
    exit 1i32;
};

pub func:main = int32(int32:argc, wild int8->:argv) {
    int64:list = raw SortedList.create();
    if (list == 0i64) { return 1i32; }

    drop raw SortedList.insert(list, 50i64);
    drop raw SortedList.insert(list, 10i64);
    drop raw SortedList.insert(list, 30i64);
    drop raw SortedList.insert(list, 20i64);
    drop raw SortedList.insert(list, 40i64);

    if (raw SortedList.count(list) != 5i64) { return 2i32; }

    if (raw SortedList.pop_front(list) != 10i64) { return 3i32; }
    if (raw SortedList.pop_front(list) != 20i64) { return 4i32; }
    if (raw SortedList.pop_front(list) != 30i64) { return 5i32; }
    if (raw SortedList.pop_front(list) != 40i64) { return 6i32; }
    if (raw SortedList.pop_front(list) != 50i64) { return 7i32; }
    
    if (raw SortedList.count(list) != 0i64) { return 8i32; }

    drop raw SortedList.destroy(list);
    
    exit 0i32;
};
