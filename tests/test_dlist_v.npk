use "../src/doubly_v.npk".*;
use "../src/types.npk".*;



func:main = int32() {
    int64:list = raw DListV.create();
    if (list == 0i64) { exit 1i32; }

    // Test push_front
    drop DListV.push_front(list, LIST_TAG_INT64, 10i64);
    drop DListV.push_front(list, LIST_TAG_FLOAT64, 20i64);
    if (raw DListV.count(list) != 2i64) { exit 2i32; }

    // Test pop_front
    if (raw DListV.pop_front_tag(list) != LIST_TAG_FLOAT64) { exit 3i32; }
    if (raw DListV.pop_front_val(list) != 20i64) { exit 4i32; }
    drop DListV.pop_front(list);
    
    if (raw DListV.pop_front_val(list) != 10i64) { exit 5i32; }
    drop DListV.pop_front(list);
    if (raw DListV.count(list) != 0i64) { exit 6i32; }

    // Test push_back and pop_back
    drop DListV.push_back(list, LIST_TAG_PTR, 100i64);
    drop DListV.push_back(list, LIST_TAG_BYTES, 200i64);
    drop DListV.push_back(list, LIST_TAG_INT64, 300i64);
    if (raw DListV.count(list) != 3i64) { exit 7i32; }

    if (raw DListV.pop_back_tag(list) != LIST_TAG_INT64) { exit 8i32; }
    if (raw DListV.pop_back_val(list) != 300i64) { exit 9i32; }
    drop DListV.pop_back(list);

    if (raw DListV.pop_front_tag(list) != LIST_TAG_PTR) { exit 10i32; }
    if (raw DListV.pop_front_val(list) != 100i64) { exit 11i32; }
    drop DListV.pop_front(list);
    
    if (raw DListV.count(list) != 1i64) { exit 12i32; }

    // Cleanup
    drop DListV.destroy(list);
    
    exit 0i32;
};
