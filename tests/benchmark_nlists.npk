// tests/benchmark_nlists.npk
use "../src/singly.npk".*;
use "../src/doubly.npk".*;
use "../src/sorted.npk".*;
use "../src/skiplist.npk".*;

pub func:failsafe = int32(tbb32:err) { exit 1i32; };

// Simple pseudorandom number generator
pub func:hash_int64 = int64(int64:key) {
    key = key ^ (key >> 30i64);
    key = key * -4265267296055464877i64;
    key = key ^ (key >> 27i64);
    key = key * -4007235288047910137i64;
    key = key ^ (key >> 31i64);
    pass key;
};

func:main = int32() {
    // 100,000 insertions to benchmark
    int64:num_items = 100000i64;
    
    // 1. Benchmark SList Push Front
    int64:slist = raw SList_create::<int64>();
    till (num_items, 1i64) {
        drop SList_push_front::<int64>(slist, $);
    }
    drop SList_destroy::<int64>(slist);
    
    // 2. Benchmark DList Push Back
    int64:dlist = raw DList_create::<int64>();
    till (num_items, 1i64) {
        drop DList_push_back::<int64>(dlist, $);
    }
    drop DList_destroy::<int64>(dlist);
    
    // 3. Benchmark SkipList Insert
    int64:skip = raw SkipList_create::<int64>();
    till (num_items, 1i64) {
        int64:rand_key = raw hash_int64($);
        if (rand_key < 0i64) { rand_key = rand_key * -1i64; }
        // keep values manageable
        rand_key = rand_key % (num_items * 10i64);
        drop SkipList_insert::<int64>(skip, rand_key);
    }
    
    // 4. Benchmark SkipList Read
    till (num_items, 1i64) {
        int64:rand_key = raw hash_int64($);
        if (rand_key < 0i64) { rand_key = rand_key * -1i64; }
        rand_key = rand_key % (num_items * 10i64);
        drop SkipList_contains::<int64>(skip, rand_key);
    }
    
    drop SkipList_destroy::<int64>(skip);
    
    // We intentionally omit SortedList for 100,000 items as its O(N) insertion
    // would take exceptionally long and muddy the execution results of the 
    // highly optimized O(1) and O(log N) operations tested above.
    
    exit 0i32;
};
