use "../src/doubly.npk".*;

func:failsafe = int32(tbb32:err) { exit 99i32; };

func:main = int32() {
    int64:list = raw DList_create<int64>();
    if (list == 0i64) { exit 1i32; }

    // Test push_front
    drop DList_push_front<int64>(list, 10i64);
    drop DList_push_front<int64>(list, 20i64);
    if (raw DList_count<int64>(list) != 2i64) { exit 2i32; }

    // Test pop_front
    if (raw DList_pop_front<int64>(list) != 20i64) { exit 3i32; }
    if (raw DList_pop_front<int64>(list) != 10i64) { exit 4i32; }
    if (raw DList_count<int64>(list) != 0i64) { exit 5i32; }

    // Test push_back and pop_back
    drop DList_push_back<int64>(list, 100i64);
    drop DList_push_back<int64>(list, 200i64);
    drop DList_push_back<int64>(list, 300i64);
    if (raw DList_count<int64>(list) != 3i64) { exit 6i32; }

    if (raw DList_pop_back<int64>(list) != 300i64) { exit 7i32; }
    if (raw DList_pop_front<int64>(list) != 100i64) { exit 8i32; }
    if (raw DList_count<int64>(list) != 1i64) { exit 9i32; }

    // Test contains and remove
    drop DList_push_back<int64>(list, 400i64); // List is [200, 400]
    if (raw DList_contains<int64>(list, 400i64) != 1i8) { exit 10i32; }
    
    drop DList_remove<int64>(list, 200i64); // List is [400]
    if (raw DList_count<int64>(list) != 1i64) { exit 11i32; }
    if (raw DList_pop_front<int64>(list) != 400i64) { exit 12i32; }

    // Test insert before / after
    drop DList_push_back<int64>(list, 50i64); // List [50]
    drop DList_insert_before<int64>(list, 50i64, 40i64); // List [40, 50]
    drop DList_insert_after<int64>(list, 50i64, 60i64); // List [40, 50, 60]

    if (raw DList_pop_front<int64>(list) != 40i64) { exit 13i32; }
    if (raw DList_pop_front<int64>(list) != 50i64) { exit 14i32; }
    if (raw DList_pop_front<int64>(list) != 60i64) { exit 15i32; }

    // Cleanup
    drop DList_destroy<int64>(list);
    
    exit 0i32;
};
