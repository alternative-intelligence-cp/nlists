use "../src/singly.npk".*;

pub func:failsafe = int32(tbb32:err) {
    exit 1i32;
};

pub func:main = int32(int32:argc, wild int8->:argv) {
    int64:list = raw SList.create();
    if (list == 0i64) { return 1i32; }

    // Test push_front
    drop raw SList.push_front(list, 10i64);
    drop raw SList.push_front(list, 20i64);
    if (raw SList.count(list) != 2i64) { return 2i32; }

    // Test pop_front
    if (raw SList.pop_front(list) != 20i64) { return 3i32; }
    if (raw SList.pop_front(list) != 10i64) { return 4i32; }
    if (raw SList.count(list) != 0i64) { return 5i32; }

    // Test push_back
    drop raw SList.push_back(list, 100i64);
    drop raw SList.push_back(list, 200i64);
    drop raw SList.push_back(list, 300i64);
    if (raw SList.count(list) != 3i64) { return 6i32; }

    // Test contains
    if (raw SList.contains(list, 200i64) != 1i8) { return 7i32; }
    if (raw SList.contains(list, 999i64) != 0i8) { return 8i32; }

    // Test remove_first
    if (raw SList.remove_first(list, 200i64) != 1i8) { return 9i32; }
    if (raw SList.count(list) != 2i64) { return 10i32; }

    // Test reverse
    drop raw SList.reverse(list);
    if (raw SList.pop_front(list) != 300i64) { return 11i32; }

    // Cleanup
    drop raw SList.destroy(list);
    
    exit 0i32;
};
