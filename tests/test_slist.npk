use "../src/singly.npk".*;



func:main = int32() {
    int64:list = raw SList_create();
    if (list == 0i64) { exit 1i32; }

    // Test push_front
    drop SList_push_front(list, 10i64);
    drop SList_push_front(list, 20i64);
    if (raw SList_count(list) != 2i64) { exit 2i32; }

    // Test pop_front
    if (raw SList_pop_front(list) != 20i64) { exit 3i32; }
    if (raw SList_pop_front(list) != 10i64) { exit 4i32; }
    if (raw SList_count(list) != 0i64) { exit 5i32; }

    // Test push_back
    drop SList_push_back(list, 100i64);
    drop SList_push_back(list, 200i64);
    drop SList_push_back(list, 300i64);
    if (raw SList_count(list) != 3i64) { exit 6i32; }

    // Test contains
    if (raw SList_contains(list, 200i64) != 1i8) { exit 7i32; }
    if (raw SList_contains(list, 999i64) != 0i8) { exit 8i32; }

    // Test remove_first
    if (raw SList_remove_first(list, 200i64) != 1i8) { exit 9i32; }
    if (raw SList_count(list) != 2i64) { exit 10i32; }

    // Test reverse
    drop SList_reverse(list);
    if (raw SList_pop_front(list) != 300i64) { exit 11i32; }

    // Cleanup
    drop SList_destroy(list);
    
    exit 0i32;
};
