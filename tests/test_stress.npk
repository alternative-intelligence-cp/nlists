// tests/test_stress.npk
use "../src/singly.npk".*;
use "../src/doubly.npk".*;
use "../src/sorted.npk".*;
use "../src/skiplist.npk".*;

func:failsafe = int32(tbb32:err) { exit 1i32; };

// Simple pseudorandom number generator for hashing tests
pub func:hash_int64 = int64(int64:key) {
    key = key ^ (key >> 30i64);
    key = key * -4265267296055464877i64;
    key = key ^ (key >> 27i64);
    key = key * -4007235288047910137i64;
    key = key ^ (key >> 31i64);
    pass key;
};

func:main = int32() {
    int64:num_items = 10000i64;
    
    // 1. SList Stress
    int64:slist = raw SList_create::<int64>();
    till (num_items, 1i64) {
        drop SList_push_front::<int64>(slist, $);
    }
    if (raw SList_count::<int64>(slist) != num_items) { exit 2i32; }
    
    till (num_items, 1i64) {
        drop SList_pop_front::<int64>(slist);
    }
    if (raw SList_count::<int64>(slist) != 0i64) { exit 3i32; }
    drop SList_destroy::<int64>(slist);
    
    // 2. DList Stress
    int64:dlist = raw DList_create::<int64>();
    till (num_items, 1i64) {
        drop DList_push_back::<int64>(dlist, $);
    }
    if (raw DList_count::<int64>(dlist) != num_items) { exit 4i32; }
    
    till (num_items, 1i64) {
        drop DList_pop_back::<int64>(dlist);
    }
    if (raw DList_count::<int64>(dlist) != 0i64) { exit 5i32; }
    drop DList_destroy::<int64>(dlist);
    
    // 3. SortedList Stress
    int64:sorted = raw SortedList_create::<int64>();
    // use a smaller amount because insertion is O(N) linear scan

func:failsafe = int32(tbb32:err) { exit 1i32; };

    till (1000i64, 1i64) {
        int64:rand_key = raw hash_int64($);
        // keep it positive and small for easier bounds
        if (rand_key < 0i64) { rand_key = rand_key * -1i64; }
        rand_key = rand_key % 10000i64;
        drop SortedList_insert::<int64>(sorted, rand_key);
    }
    if (raw SortedList_count::<int64>(sorted) != 1000i64) { exit 6i32; }
    drop SortedList_destroy::<int64>(sorted);
    
    // 4. SkipList Stress
    int64:skip = raw SkipList_create::<int64>();
    till (2000i64, 1i64) {
        int64:rand_key = raw hash_int64($);
        drop SkipList_insert::<int64>(skip, rand_key);
    }
    if (raw SkipList_count::<int64>(skip) != 2000i64) { exit 7i32; }
    
    till (1000i64, 1i64) {
        int64:rand_key = raw hash_int64($);
        drop SkipList_remove::<int64>(skip, rand_key);
    }
    if (raw SkipList_count::<int64>(skip) != 1000i64) { exit 8i32; }
    drop SkipList_destroy::<int64>(skip);

    exit 0i32;
};
