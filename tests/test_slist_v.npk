use "../src/singly_v.npk".*;
use "../src/types.npk".*;



func:main = int32() {
    int64:list = raw SListV.create();
    if (list == 0i64) { exit 1i32; }

    // Test push_front
    drop SListV.push_front(list, LIST_TAG_INT64, 10i64);
    drop SListV.push_front(list, LIST_TAG_FLOAT64, 20i64);
    if (raw SListV.count(list) != 2i64) { exit 2i32; }

    // Test pop_front values and tags
    if (raw SListV.pop_front_tag(list) != LIST_TAG_FLOAT64) { exit 3i32; }
    if (raw SListV.pop_front_val(list) != 20i64) { exit 4i32; }
    drop SListV.pop_front(list);

    if (raw SListV.pop_front_tag(list) != LIST_TAG_INT64) { exit 5i32; }
    if (raw SListV.pop_front_val(list) != 10i64) { exit 6i32; }
    drop SListV.pop_front(list);
    if (raw SListV.count(list) != 0i64) { exit 7i32; }

    // Test push_back
    drop SListV.push_back(list, LIST_TAG_PTR, 100i64);
    drop SListV.push_back(list, LIST_TAG_BYTES, 200i64);
    if (raw SListV.count(list) != 2i64) { exit 8i32; }

    if (raw SListV.pop_front_tag(list) != LIST_TAG_PTR) { exit 9i32; }
    if (raw SListV.pop_front_val(list) != 100i64) { exit 10i32; }
    drop SListV.pop_front(list);

    // Cleanup
    drop SListV.destroy(list);
    
    exit 0i32;
};
